{
  "name": "towerdefense-marvel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node dev-server.js",
    "test": "node --test",
    "validate": "node scripts/validate-data.js",
    "validate:strict": "node scripts/validate-data.js --strict-assets",
    "build:data": "node scripts/build-bootstrap-data.js",
    "build:atlas": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-sprite-atlas.ps1",
    "balance": "node scripts/simulate-economy.js",
    "benchmark": "node scripts/benchmark-combat.js",
    "release:check": "node scripts/validate-release.js",
    "check": "npm run validate && npm test && npm run balance && npm run benchmark && npm run release:check"
  }
}
